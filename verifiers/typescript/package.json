{
  "name": "@paolino/csmt-verify",
  "version": "0.1.0",
  "description": "TypeScript library for verifying CSMT inclusion proofs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "merkle",
    "tree",
    "csmt",
    "proof",
    "verification",
    "cryptography",
    "blake2b"
  ],
  "author": "Paolo Veronelli",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lambdasistemi/haskell-mts.git",
    "directory": "verifiers/typescript"
  },
  "dependencies": {
    "blakejs": "^1.2.1",
    "cbor-x": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
