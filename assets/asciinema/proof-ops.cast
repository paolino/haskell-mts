{"version": 2, "width": 80, "height": 24, "timestamp": 1770038730, "env": {"SHELL": "/bin/bash", "TERM": "tmux-256color"}}
[0.033322, "o", "# CSMT Proof Operations Demo\r\n\r\n"]
[1.033257, "o", "## Setup: Insert data\r\n"]
[1.536693, "o", "$ csmt <<< \"i mykey myvalue\"\r\n"]
[1.732441, "o", "AddedKey\r\n"]
[2.752628, "o", "\r\n## Generate inclusion proof\r\n"]
[3.25607, "o", "$ PROOF=$(csmt <<< \"q mykey\")\r\n"]
[3.3611, "o", "hZgoAAEBAAEBAAEAAQEBAQAAAQABAQABAAEBAAEBAAABAAEAAQEBAQAAAVgggB0G/eKO8/HuMy7fJKAOw3q5VGFAI4DrY+CCzPOAVSNYIMynNn90bz9BstGj20pUq+Yj3hid/EGZkgTQC2uTWgoJgJgoAAEBAAEBAAEAAQEBAQAAAQABAQABAAEBAAEBAAABAAEAAQEBAQAAAQ==\r\n"]
[5.364804, "o", "\r\n## Verify inclusion proof\r\n"]
[5.870552, "o", "$ echo \"v $PROOF\" | csmt\r\n"]
[5.932001, "o", "Valid"]
[5.933297, "o", "\r\n"]
[7.955234, "o", "\r\n## Proof is self-contained (works without DB)\r\n"]
[8.459729, "o", "$ rm -rf $CSMT_DB_PATH\r\n"]
[8.970259, "o", "$ echo \"v $PROOF\" | csmt\r\n"]
[9.036824, "o", "Valid\r\n"]
